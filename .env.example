# ==========================================
# LifeOS Environment Configuration
# ==========================================

# Database
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=lifeos
DATABASE_URL=Host=postgres;Database=lifeos;Username=lifeos;Password=change_me_in_production

# JWT
JWT_SECRET=change_this_to_a_64_character_random_string_for_production
JWT_ISSUER=LifeOS
JWT_AUDIENCE=LifeOS
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# AI
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
AI_PROVIDER=gemini

# Frontend
VITE_API_BASE_URL=/api

# Docker / Unraid
COMPOSE_PROJECT_NAME=lifeos

# Scrapers / External APIs
MUSE_API_KEY=

# Notifications (Phase 2)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
